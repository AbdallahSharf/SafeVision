# =============================================================================
# SafeVision — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (REQUIRED — no default)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=MyApp

# RTSP camera URL (REQUIRED — no default)
RTSP_URL=rtsp://admin:password@your-ddns-hostname.com:554/cam/realmonitor?channel=1&subtype=0

# ── Security & Alerts ────────────────────────────────────────────────────────

# Bearer token for protected admin endpoints (leave empty to disable auth in dev)
# API_SECRET_KEY=

# Path to Firebase service account JSON (leave empty to disable push notifications)
# FIREBASE_CREDENTIALS_PATH=

# FCM topic for push notifications (default: safevision-alerts)
# FCM_TOPIC=safevision-alerts

# ── Server ───────────────────────────────────────────────────────────────────

# Port for the FastAPI server (default: 8080)
# PORT=8080

# Set to "true" to enable local OpenCV window display (disable on servers)
# DISPLAY_OUTPUT=false

# ── Model Paths ──────────────────────────────────────────────────────────────

# YOLO_MODEL_PATH=models/best.pt
# ARCFACE_MODEL_PATH=models/w600k_r50.onnx

# ── Detection Thresholds ─────────────────────────────────────────────────────

# YOLO confidence threshold (0.0–1.0, default: 0.4)
# YOLO_CONF_THRESHOLD=0.4

# Bounding box confidence threshold (default: 0.4)
# BOX_CONF_THRESHOLD=0.4

# Face recognition similarity threshold (default: 0.45)
# RECOG_THRESHOLD=0.45

# ── Frame Processing ─────────────────────────────────────────────────────────

# FRAME_WIDTH=640
# FRAME_HEIGHT=480
# FACE_SIZE=112
# FACE_MARGIN=20
# IMGSZ=640
# QUEUE_SIZE=2
# HISTORY_LEN=5
# QUEUE_TIMEOUT=2.0

# ── Streaming ────────────────────────────────────────────────────────────────

# JPEG quality for the MJPEG stream (default: 70)
# STREAM_JPEG_QUALITY=70

# Target FPS for the MJPEG stream output (default: 15)
# TARGET_STREAM_FPS=15

# ── Face Quality Gate ────────────────────────────────────────────────────────

# Laplacian variance blur threshold (default: 80.0)
# BLUR_THRESHOLD=80.0

# ── Frame Skipping ───────────────────────────────────────────────────────────

# Run YOLO every N-th frame (default: 2)
# DETECT_EVERY_N_FRAMES=2

# ── MongoDB Vector Search ────────────────────────────────────────────────────

# DB_NUM_CANDIDATES=100
# DB_TOP_K=5

# ── Low-Light Enhancement ────────────────────────────────────────────────────

# Enable/disable low-light auto-enhancement (default: false)
# LOW_LIGHT_ENABLE=false

# Mean brightness threshold (0–255); enhancement triggers below this
# LOW_LIGHT_AUTO_THRESHOLD=80

# CLAHE clip limit (2.0–4.0; higher = stronger contrast boost)
# CLAHE_CLIP_LIMIT=3.0

# CLAHE grid tile size
# CLAHE_TILE_SIZE=8

# Denoise strength (0=off, 3–10=light–strong; higher costs FPS, default: 0)
# DENOISE_STRENGTH=0

# ── GPU ──────────────────────────────────────────────────────────────────────

# Use GPU for stream decoding (default: true)
# USE_GPU_DECODE=true

# ── FAISS Local Index ────────────────────────────────────────────────────────

# Seconds between periodic syncs of the FAISS index with MongoDB (default: 60)
# FAISS_SYNC_INTERVAL=60

# ── Alert Rate Limiting ──────────────────────────────────────────────────────

# Minimum seconds between consecutive FCM alerts (default: 60)
# ALERT_COOLDOWN_SECONDS=60
