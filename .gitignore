# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
venv/
.venv/
test-env/
venv2/

# Environment (secrets — NEVER commit)
.env

# Logs
*.log
safevision.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Model weights — stored in GCS, downloaded at Docker build time
# Do NOT commit .pt / .onnx / .engine — they caused Git LFS quota failures
models/*.pt
models/*.onnx
models/*.engine

# Firebase credentials (NEVER commit)
*-firebase-adminsdk-*.json
serviceAccountKey.json

# Secret keys and certificates
*.pem
*.key
*.secret